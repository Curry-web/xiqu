# xiqu local environment template
# Copy this file to `.env` and fill local secrets. Do not commit real keys.

# -----------------------------
# sage-wiki workspace
# -----------------------------
SAGE_WIKI_DIR=wiki/xiqu-knowledge
SAGE_WIKI_SOURCE_DIR=2026大创项目（戏曲智能体）
# docs: only documents; images: only images; docs,images: both. Videos are always skipped.
SAGE_WIKI_BATCH=docs
SAGE_WIKI_UI_PORT=3333

# -----------------------------
# NVIDIA NIM for sage-wiki
# -----------------------------
# Current project uses NVIDIA NIM only.
# Switch NVIDIA chat or embedding models by changing NVIDIA_MODEL / NVIDIA_EMBED_MODEL here.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embed-v1

# Optional NVIDIA / sage-wiki knobs
NVIDIA_RATE_LIMIT=30
NVIDIA_TEMPERATURE=0.2
NVIDIA_TOP_P=0.7
NVIDIA_EMBED_PROVIDER=openai

# -----------------------------
# Agent API
# -----------------------------
AGENT_PORT=8787
AGENT_HOST=127.0.0.1
# 1: /api/agent/ask lets the agent synthesize an answer from retrieved wiki context; 0: BM25-only fallback.
AGENT_USE_LLM=1
AGENT_SEARCH_LIMIT=8
AGENT_LLM_TIMEOUT_SECONDS=60

# Optional build-script switches
# SAGE_WIKI_SKIP_DOCTOR=1
# SAGE_WIKI_SKIP_COMPILE=1
# SAGE_WIKI_SKIP_SEARCH=1
# SAGE_WIKI_SKIP_QUERY=1

# Show more sage-wiki compile logs. Use -v, -vv, or empty to disable.
SAGE_WIKI_COMPILE_VERBOSE=-v

# sage-wiki HTTP timeouts (seconds)
SAGE_WIKI_HTTP_TIMEOUT_SECONDS=300
SAGE_WIKI_EMBED_TIMEOUT_SECONDS=300
